# Supabase project settings (Project Settings > API in the Supabase dashboard)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key (Project Settings > API > service_role). Server-only —
# never expose with NEXT_PUBLIC_. Used to store the Shopify token.
SUPABASE_SERVICE_ROLE_KEY=

# Shopify custom app (Dev Dashboard > Heart Magic HQ > Settings > Credentials)
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_SHOP_DOMAIN=
# Public URL of this deployed app, used to build the OAuth redirect URI.
SHOPIFY_APP_URL=

# Google Drive Picker (Settings-adjacent: lets "Linked documents" fields
# browse real Drive files instead of pasting URLs by hand). Both values
# are meant to be public/client-side, like a Google Maps API key — they're
# restricted by HTTP referrer + API in Google Cloud Console, not secret.
# See SETUP.md Section 4 for exactly where to get these.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_PICKER_API_KEY=
